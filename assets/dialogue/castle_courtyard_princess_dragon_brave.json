      "tone": "FRIENDLY",
      "branches": [],
      "outcome": "MOOD_POSITIVE"
    },
    {
      "nodeId": "node_5",
      "speaker": "princess",
      "characterLine": {
        "en": "It's risky to stay outside. Let's hurry next time.",
        "nl": "Het is gevaarlijk om buiten te blijven. Laten we de volgende keer opschieten."
      },
      "tone": "NEUTRAL",
      "branches": [],
      "outcome": "NEUTRAL"
    },
    {
      "nodeId": "node_6",
      "speaker": "princess",
      "characterLine": {
        "en": "Good! My song makes the thunder less scary.",
        "nl": "Goed zo! Mijn liedje maakt de donder minder eng."

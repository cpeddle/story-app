      "tone": "FRIENDLY",
      "branches": [],
      "outcome": "MOOD_POSITIVE"
    },
    {
      "nodeId": "node_9",
      "speaker": "princess",
      "characterLine": {
        "en": "It's okay to be scared. Let's find a safe place.",
        "nl": "Het is oké om bang te zijn. Laten we een veilige plek zoeken."
      },
      "tone": "FRIENDLY",
      "branches": [],
      "outcome": "MOOD_NEGATIVE"

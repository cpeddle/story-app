  "nodes": [
    {
      "nodeId": "node_0",
      "speaker": "princess",
      "characterLine": {
        "en": "Don't be scared of thunder, Dragon! I'll protect you.",
        "nl": "Wees niet bang voor de donder, Draak! Ik bescherm jou."
      },
      "tone": "FRIENDLY",
      "branches": [
        {
          "branchId": "br_0_1",
          "playerLabel": {
            "en": "Let's hide inside.",
            "nl": "Laten we binnen gaan schuilen."
          },
          "targetNodeId": "node_1"
        },
        {
          "branchId": "br_0_2",
          "playerLabel": {
            "en": "I will sing a song.",
            "nl": "Ik ga een liedje zingen."
          },
          "targetNodeId": "node_2"
        },
        {
          "branchId": "br_0_3",
          "playerLabel": {
            "en": "Look at the lightning!",
            "nl": "Kijk naar de bliksem!"
          },
          "targetNodeId": "node_3"
        }
      ]
    },
    {
      "nodeId": "node_1",
      "speaker": "princess",
      "characterLine": {
        "en": "Let's go to the castle. It's safe and warm there.",
        "nl": "Laten we naar het kasteel gaan. Daar is het veilig en warm."
      },
      "tone": "FRIENDLY",
      "branches": [
        {
          "branchId": "br_1_1",
          "playerLabel": {
            "en": "Follow me!",
            "nl": "Volg mij!"
          },
          "targetNodeId": "node_4"
        },
        {
          "branchId": "br_1_2",
          "playerLabel": {
            "en": "Wait, stay here!",
            "nl": "Wacht, blijf hier!"
          },
          "targetNodeId": "node_5"
        }
      ]
    },
    {
      "nodeId": "node_2",
      "speaker": "princess",
      "characterLine": {
        "en": "Hush now, listen to my song. Thunder is just noise.",
        "nl": "Ssst, luister naar mijn liedje. Donder is maar lawaai."

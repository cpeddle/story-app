      "tone": "FRIENDLY",
      "branches": [],
      "outcome": "MOOD_POSITIVE"
    },
    {
      "nodeId": "node_7",
      "speaker": "princess",
      "characterLine": {
        "en": "Oh, the thunder is still loud. Let's try something else.",
        "nl": "Oh, de donder is nog steeds hard. Laten we iets anders proberen."
      },
      "tone": "NEUTRAL",
      "branches": [],
      "outcome": "NEUTRAL"
    },
    {
      "nodeId": "node_8",
      "speaker": "princess",
      "characterLine": {
        "en": "Yes! Lightning is pretty, not scary like thunder.",
        "nl": "Ja! Bliksem is mooi, niet eng zoals donder."

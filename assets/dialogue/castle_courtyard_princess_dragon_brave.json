        {
          "branchId": "br_2_2",
          "playerLabel": {
            "en": "Stop singing.",
            "nl": "Stop met zingen."
          },
          "targetNodeId": "node_7"
        }
      ]
    },
    {
      "nodeId": "node_3",
      "speaker": "princess",
      "characterLine": {
        "en": "See the bright lightning? It lights up the whole sky!",
        "nl": "Zie je die felle bliksem? Die verlicht de hele lucht!"
      },
      "tone": "FRIENDLY",
      "branches": [
        {
          "branchId": "br_3_1",
          "playerLabel": {
            "en": "Isn't it beautiful?",
            "nl": "Is het niet mooi?"
          },
          "targetNodeId": "node_8"
        },
        {
          "branchId": "br_3_2",
          "playerLabel": {
            "en": "It's too scary.",
            "nl": "Het is te eng."
          },
          "targetNodeId": "node_9"
        }

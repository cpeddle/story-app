{
  "treeId": "throneroom_knight_dragon_curious_001",
  "scenarioId": "throneroom_curious_helmet",
  "traitId": "CURIOUS",
  "rootNodeId": "node_0",
  "nodes": [
    {
      "nodeId": "node_0",
      "speaker": "dragon",
      "characterLine": {
        "en": "Why do you wear that heavy helmet inside?",
        "nl": "Waarom draag je die zware helm binnen?"
      },
      "tone": "FRIENDLY",
      "branches": [
        {
          "branchId": "br_0_1",
          "playerLabel": {
            "en": "It feels safe.",
            "nl": "Ik voel me er veilig door."
          },
          "targetNodeId": "node_1"
        },
        {
          "branchId": "br_0_2",
          "playerLabel": {
            "en": "It's part of my armor.",
            "nl": "Het hoort bij mijn harnas."
          },
          "targetNodeId": "node_2"
        },
        {
          "branchId": "br_0_3",
          "playerLabel": {
            "en": "Do you not feel warm?",
            "nl": "Word je er niet warm van?"
          },
          "targetNodeId": "node_3"
        }
      ]
    },
    {
      "nodeId": "node_1",
      "speaker": "knight",
      "characterLine": {
        "en": "Yes, it keeps me brave and strong inside.",
        "nl": "Ja, het maakt me vanbinnen dapper en sterk."
      },
      "tone": "NEUTRAL",
      "branches": [
        {
          "branchId": "br_1_1",
          "playerLabel": {
            "en": "Can I try it on?",
            "nl": "Mag ik het eens proberen?"
          },
          "targetNodeId": "node_4"
        },
        {
          "branchId": "br_1_2",
          "playerLabel": {
            "en": "Maybe you can take it off!",
            "nl": "Misschien kun je het afzetten!"
          },
          "targetNodeId": "node_5"
        }
      ]
    },
    {
      "nodeId": "node_2",
      "speaker": "knight",
      "characterLine": {
        "en": "Yes! It shows I am ready to protect the castle.",
        "nl": "Ja! Het laat zien dat ik klaar ben om het kasteel te beschermen."
      },
      "tone": "FRIENDLY",
      "branches": [
        {
          "branchId": "br_2_1",
          "playerLabel": {
            "en": "I want to protect too!",
            "nl": "Ik wil ook beschermen!"
          },
          "targetNodeId": "node_4"
        },
        {
          "branchId": "br_2_2",
          "playerLabel": {
            "en": "Does it ever get heavy?",
            "nl": "Wordt het soms niet te zwaar?"
          },
          "targetNodeId": "node_6"
        }
      ]
    },
    {
      "nodeId": "node_3",
      "speaker": "knight",
      "characterLine": {
        "en": "Sometimes, but courage feels warmer than sun.",
        "nl": "Soms wel, maar moed voelt warmer dan de zon."
      },
      "tone": "FRIENDLY",
      "branches": [
        {
          "branchId": "br_3_1",
          "playerLabel": {
            "en": "That is a nice thought.",
            "nl": "Dat is een mooie gedachte."
          },
          "targetNodeId": "node_7"
        },
        {
          "branchId": "br_3_2",
          "playerLabel": {
            "en": "Maybe try without helmet?",
            "nl": "Misschien eens zonder helm proberen?"
          },
          "targetNodeId": "node_5"
        }
      ]
    },
    {
      "nodeId": "node_4",
      "speaker": "knight",
      "characterLine": {
        "en": "Be careful, it can be heavy and tight!",
        "nl": "Pas op, het kan zwaar en strak zitten!"
      },
      "tone": "NEUTRAL",
      "branches": [
        {
          "branchId": "br_4_1",
          "playerLabel": {
            "en": "I love feeling brave!",
            "nl": "Ik vind het fijn om dapper te zijn!"
          },
          "targetNodeId": "node_8"
        },
        {
          "branchId": "br_4_2",
          "playerLabel": {
            "en": "It hurts my head!",
            "nl": "Het doet pijn aan mijn hoofd!"
          },
          "targetNodeId": "node_9"
        }
      ]
    },
    {
      "nodeId": "node_5",
      "speaker": "knight",
      "characterLine": {
        "en": "Maybe one day, but for now it stays on.",
        "nl": "Misschien ooit, maar nu blijft hij op."
      },
      "tone": "NEUTRAL",
      "branches": [
        {
          "branchId": "br_5_1",
          "playerLabel": {
            "en": "I understand, thank you!",
            "nl": "Ik snap het, dank je!"
          },
          "targetNodeId": "node_7"
        },
        {
          "branchId": "br_5_2",
          "playerLabel": {
            "en": "I wish you could try fresh air.",
            "nl": "Ik zou willen dat je frisse lucht kon voelen."
          },
          "targetNodeId": "node_9"
        }
      ]
    },
    {
      "nodeId": "node_6",
      "speaker": "knight",
      "characterLine": {
        "en": "Yes, but that is the price to protect all.",
        "nl": "Ja, maar dat is de prijs om iedereen te beschermen."
      },
      "tone": "NEUTRAL",
      "branches": [
        {
          "branchId": "br_6_1",
          "playerLabel": {
            "en": "You are very brave!",
            "nl": "Jij bent echt dapper!"
          },
          "targetNodeId": "node_8"
        },
        {
          "branchId": "br_6_2",
          "playerLabel": {
            "en": "Maybe rest without helmet sometimes?",
            "nl": "Misschien soms rusten zonder helm?"
          },
          "targetNodeId": "node_5"
        }
      ]
    },
    {
      "nodeId": "node_7",
      "speaker": "dragon",
      "characterLine": {
        "en": "Thank you for explaining. I like learning!",
        "nl": "Dank je voor het uitleggen. Ik vind leren leuk!"
      },
      "tone": "FRIENDLY",
      "branches": [],
      "outcome": "MOOD_POSITIVE"
    },
    {
      "nodeId": "node_8",
      "speaker": "dragon",
      "characterLine": {
        "en": "You are so brave! I want to be like you!",
        "nl": "Je bent zo dapper! Ik wil net als jij zijn!"
      },
      "tone": "FRIENDLY",
      "branches": [],
      "outcome": "MOOD_POSITIVE"
    },
    {
      "nodeId": "node_9",
      "speaker": "dragon",
      "characterLine": {
        "en": "Oh no! Maybe helmet is too hard for you.",
        "nl": "Oh nee! Misschien is de helm te zwaar voor jou."
      },
      "tone": "FRIENDLY",
      "branches": [],
      "outcome": "MOOD_NEGATIVE"
    }
  ]
}